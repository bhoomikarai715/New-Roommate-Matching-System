# Vercel Production Environment Variables Example
# Set these in your Vercel Dashboard -> Project -> Settings -> Environment Variables

# DATABASE_URL: Your PostgreSQL connection string. Ensure it uses postgresql:// and NOT postgres://
DATABASE_URL="postgresql://user:password@host:port/database"

# SECRET_KEY: A highly secure random string for JWT token generation
SECRET_KEY="replace-this-with-a-32-character-random-secure-string"

# ALGORITHM: The algorithm used for JWT
ALGORITHM="HS256"

# ACCESS_TOKEN_EXPIRE_MINUTES: Time in minutes before session expires
ACCESS_TOKEN_EXPIRE_MINUTES=10080
